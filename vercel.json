{
    "buildCommand": "vite build",
    "outputDirectory": "dist",
    "installCommand": "npm install",
    "framework": "vite",
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "https://atmilan-backend.onrender.com/api/:path*"
        },
        {
            "source": "/uploads/:path*",
            "destination": "https://atmilan-backend.onrender.com/uploads/:path*"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}